{
  "name": "@world-harness/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/listen.ts",
    "start": "node dist/src/listen.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@world-harness/core": "workspace:*",
    "@world-harness/models": "workspace:*",
    "@world-harness/orchestrator": "workspace:*",
    "@world-harness/policy": "workspace:*",
    "@world-harness/tools": "workspace:*",
    "@world-harness/workspace": "workspace:*"
  },
  "exports": {
    "./src/index.js": "./src/index.ts",
    ".": "./src/index.ts"
  }
}
